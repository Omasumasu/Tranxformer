{
  "name": "tranxformer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "lucide-react": "^0.400",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@playwright/test": "^1",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "husky": "^9.1.7",
    "jsdom": "^25",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1",
    "typescript": "^5.6",
    "vite": "^6",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --write --no-errors-on-unmatched"],
    "*.{json,css}": ["biome format --write --no-errors-on-unmatched"]
  }
}
