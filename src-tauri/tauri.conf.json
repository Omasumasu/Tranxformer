{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/.nicegui/resources/tauri/tauri.conf.json",
  "productName": "Tranxformer",
  "version": "0.1.0",
  "identifier": "com.tranxformer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tranxformer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$DOWNLOAD/**", "$HOME/**"]
      }
    }
  }
}
